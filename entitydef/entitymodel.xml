	<entity entity-name="TopicMaster" package-name="">
		<field name="topicId" type="id" />
		<field name="topicName" type="short-varchar" />

		<prim-key field="topicId" />
	</entity>
	<entity entity-name="QuestionMaster" package-name="">
		<field name="questionId" type="id" />
		<field name="questionDetail" type="description" />
		<field name="optionA" type="name" />
		<field name="optionB" type="name" />
		<field name="optionC" type="name" />
		<field name="optionD" type="name" />
		<field name="optionE" type="name"/>
		<field name="answer" type="long-answer" />
		<field name="numAnswers" type="numeric" />
		<field name="questionType" type="name" />
		<field name="difficultyLevel" type="name" />
		<field name="answerValue" type="very-long" />
		<field name="topicId" type="id" />

		<prim-key field="questionId" />
		<relation rel-entity-name="TopicMaster" fk-name="topic_id"
			type="one">
			<key-map field-name="topicId" rel-field-name="topicId" />
		</relation>
		
		<relation rel-entity-name="Enumeration" fk-name="fk_question_type"
			type="one">
			<key-map field-name="questionType" rel-field-name="enumId" />
		</relation>
	</entity>
	

	 <entity entity-name="QuestionBankMasterB" package-name="">
		<field name="examId" type="id"></field>
		<field name="qId" type="id"></field>
		<field name="topicId" type="id" not-null="true"/>
		<field name="questionDetail" type="very-long" not-null="true"></field>
		<field name="optionA" type="very-long"/>
		<field name="optionB" type="very-long"/>
		<field name="optionC" type="very-long"/>
		<field name="optionD" type="very-long"/>
		<field name="optionE" type="very-long"/>
		<field name="answer" type="very-long" not-null="true"></field>
		<field name="numAnswers" type="numeric" not-null="true"/>
		<field name="questiontype" type="name" not-null="true"></field>
		<field name="difficultyLevel" type="name"></field>
		<field name="answerValue" type="very-long"/>
		<field name="negativeMarkValue" type="numeric"></field>			
		<prim-key field="examId" />
		<prim-key field="qId" />
		<relation rel-entity-name="ExamMaster" fk-name="QUESTION_BANK_B_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>			
    </entity>
    
    <entity entity-name="QuestionBankMaster" package-name="">
		<field name="examId" type="id"/>
		<field name="qId" type="id"/>
		<field name="topicId" type="id" not-null="true"/>
		<field name="questionDetail" type="very-long" not-null="true"></field>
		<field name="optionA" type="very-long"/>
		<field name="optionB" type="very-long"/>
		<field name="optionC" type="very-long"/>
		<field name="optionD" type="very-long"/>
		<field name="optionE" type="very-long"/>
		<field name="answer" type="very-long" not-null="true"></field>
		<field name="numAnswers" type="numeric" not-null="true"/>
		<field name="questionType" type="name" not-null="true"></field>
		<field name="difficultyLevel" type="name"></field>
		<field name="answerValue" type="very-long"/>
		<field name="negativeMarkValue" type="numeric"></field>		
		<prim-key field="examId" />
		<prim-key field="qId" />
		<relation rel-entity-name="ExamMaster" fk-name="QUESTION_BANK_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>			
    </entity>
	

	<entity entity-name="ExamTopicDetails" package-name="">
		<field name="examId" type="id"/>
		<field name="topicId" type="id"/>
		<field name="topicName" type="short-varchar" not-null="true" />
		<field name="percentage" type="numeric" not-null="true"/>
		<field name="startingQid" type="numeric" />
		<field name="endingQid" type="numeric"/>
		<field name="questionsPerExam" type="numeric" />
		<field name="topicPassPercentage" type="floating-point"/>
		<prim-key field="examId" />
		<prim-key field="topicId" />
		<relation rel-entity-name="ExamMaster"
			fk-name="EXAM_TOPIC_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>

	</entity>

	<entity entity-name="ExamMaster" package-name="">
		<field name="examId" type="id"></field>
		<field name="examName" type="name"></field>
		<field name="description" type="description"></field>
		<field name="noOfQuestions" type="numeric" not-null="true"></field>
		<field name="duration" type="numeric" not-null="true"></field>
		<field name="passPercentage" type="numeric" not-null="true" />
		<field name="questionsRandomized" type="numeric"></field>
		<field name="answersMust" type="numeric"></field>
		<field name="allowNegativeMarks" type="numeric" />
		<field name="examSetupProper" type="numeric"></field>
		<field name="negativeMarkValue" type="currency-amount"></field>
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<!--field to store the adminId who created this exam -->
		<field name="createdByUserLogin" type="id-vlong"></field>
		<!--field to store the adminId who last modified this exam -->
		<field name="lastModifiedByUserLogin" type="id-vlong"></field>
		<prim-key field="examId" />
	</entity>

	<entity entity-name="ExamSetupDetails"
		package-name="">
		<field name="examId" type="id"></field>
		<field name="setupType" type="id" not-null="true"></field>
		<field name="setupDetails" type="very-long" not-null="true"></field>
		<prim-key field="examId" />
		<relation rel-entity-name="ExamMaster"
			fk-name="EXAM_SETUP_FK" type="one">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>
	</entity>
