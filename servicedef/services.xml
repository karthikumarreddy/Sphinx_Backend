<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>Sphinx Services</description>
    <vendor></vendor>
    <version>1.0</version>

    <!-- ====================================================================== -->
    <!-- ======================== USER SERVICES =========================== -->
    <!-- ====================================================================== -->
    
    <service name="loginUser" engine="java" location="com.sphinx.services.UserServices" invoke="loginUser">
        <attribute name="userName" mode="IN" type="String" />
        <attribute name="password" mode="IN" type="String" />
        <attribute name="partyId" mode="OUT" type="String"></attribute>
    </service>
    
    <service name="createParty" engine="entity-auto" default-entity-name="Party" invoke="create" auth="false">
    	<attribute name="partyId" mode="INOUT" type="String" optional="false"/>
    	<attribute name="partyTypeId" mode="IN" type="String" optional="false" />
    	<attribute name="statusId" mode="IN" type="String" optional="false" />
    </service>

	<service name="createPerson" engine="entity-auto" default-entity-name="Person" invoke="create" auth="false">
    	<attribute name="partyId" mode="INOUT" type="String" optional="false"/>
    	<attribute name="firstName" mode="IN" type="String" optional="false" />
    	<attribute name="lastName" mode="IN" type="String" optional="false" />
    </service>
    
   	<service name="createUserLogin" engine="entity-auto" default-entity-name="UserLogin" invoke="create" auth="false">
   		<attribute name="userLoginId" mode="INOUT" type="String" optional="false" />
   		<attribute name="currentPassword" mode="IN" type="String" optional="false" />
   		<attribute name="partyId" mode="IN" type="String" optional="false" />
   		<attribute name="requirePasswordChange" mode="IN" type="String" optional="false" />
   		<attribute name="enabled" mode="IN" type="String" optional="false"/>
   	</service>
   	
   	<service name="createPartyRole" engine="entity-auto" default-entity-name="PartyRole" invoke="create" auth="false">
   		<attribute name="partyId" mode="IN" type="String" optional="false" />
   		<attribute name="roleTypeId" mode="IN" type="String" optional="false" />
   		<attribute name="statusId" mode="IN" type="String" optional="false"/>
   	</service>
   	
   	<service name="createContactMech" engine="entity-auto" default-entity-name="ContactMech" invoke="create" auth="false">
   		<attribute name="contactMechId" mode="INOUT" type="String" optional="true" />
   		<attribute name="contactMechTypeId" mode="IN" type="String" optional="false" />
   		<attribute name="infoString" mode="IN" type="String" optional="false" />
   	</service>
   	
   	<service name="createPartyContactMech" engine="entity-auto" default-entity-name="PartyContactMech" invoke="create" auth="false">
   		<attribute name="partyId" mode="IN" type="String" optional="false" />
   		<attribute name="contactMechId" mode="IN" type="String" optional="false" />
   		<attribute name="fromDate" mode="IN" type="Timestamp" optional="false" />
   	</service>
   	
    
    <service name="signupUser" engine="java" location="com.sphinx.services.UserServices" invoke="signupUser">
        <attribute name="userName" mode="IN" type="String" optional="true"/>
        <attribute name="firstName" mode="IN" type="String" />
        <attribute name="lastName" mode="IN" type="String" />
        <attribute name="email" mode="IN" type="String" />
        <attribute name="password" mode="IN" type="String" optional="true" />
        <attribute name="role" mode="IN" type="String" />
    </service>

    <service name="approveUser" engine="java" location="com.sphinx.services.AdminServices" invoke="approveUser">
        <attribute name="userName" mode="IN" type="String" />
    </service>


    <!-- ====================================================================== -->
    <!-- ======================== TOPIC SERVICES =========================== -->
    <!-- ====================================================================== -->

    <!-- Topic Services -->
    <service name="createTopicValidator" engine="java" location="com.sphinx.services.TopicServices"  invoke="createTopic" default-entity-name="TopicMaster">
        <auto-attributes include="pk" mode="INOUT" optional="true" />
        <auto-attributes include="nonpk" mode="INOUT" optional="false" />
    </service>
    
    <service name="createTopic" engine="entity-auto" invoke="create" default-entity-name="TopicMaster">
        <auto-attributes include="pk" mode="INOUT" optional="true" />
        <auto-attributes include="nonpk" mode="INOUT" optional="false" />
    </service>

    <service name="updateTopic" engine="entity-auto" invoke="update" default-entity-name="TopicMaster">
        <attribute name="topicId" type="String" mode="IN" />
        <attribute name="topicName" type="String" mode="IN" />
    </service>

    <service name="deleteTopic" engine="entity-auto" invoke="delete" default-entity-name="TopicMaster">
        <attribute name="topicId" type="String" mode="IN" />
    </service>

    <service name="getAllTopics" engine="java" location="com.sphinx.services.TopicServices" invoke="getAllTopic">
        <attribute name="topicList" type="List" mode="OUT" optional="true" />
    </service>

    <service name="getTopicById" engine="java" location="com.sphinx.services.TopicServices" invoke="getTopicById">
        <attribute name="topicId" type="String" mode="IN" optional="false" />
        <attribute name="topic" type="Map" mode="OUT" optional="true" />
    </service>



    <!-- ====================================================================== -->
    <!-- ======================== EXAM TOPIC SERVICES =========================== -->
    <!-- ====================================================================== -->
    
    
    <service name="addExamTopics" default-entity-name="ExamTopicDetails" engine="entity-auto" invoke="create" auth="false">

        <auto-attributes include="pk" mode="IN" optional="false"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>
    </service>

    <service name="updateExamTopics" default-entity-name="ExamTopicDetails" engine="entity-auto" invoke="update" auth="false">
        <auto-attributes include="pk" mode="IN" optional="false"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>
    </service>

    <service name="deleteExamTopics" engine="entity-auto" invoke="delete" default-entity-name="ExamTopicDetails" auth="false">
        <attribute name="examId" type="String" mode="IN" />
        <attribute name="topicId" type="String" mode="IN" />
    </service>

    <service name="getAllExamTopics" engine="java" location="com.sphinx.services.ExamTopicServices" invoke="getAllExamTopics" auth="false">
        <attribute name="examTopicList" type="List" mode="OUT" optional="false" />
    </service>

    <service name="getExamTopicById" engine="java" location="com.sphinx.services.ExamTopicServices" invoke="getExamTopicById" auth="false">
        <attribute name="examId" type="String" mode="IN" optional="false" />
        <attribute name="topicId" type="String" mode="IN" optional="false" />
        <attribute name="examTopic" type="Map" mode="OUT" optional="true" />
    </service>

    <service name="generateExamQuestions" engine="java" location="com.sphinx.services.ExamTopicServices" invoke="generateExamQuestions" auth="false">
        <attribute name="examId" type="String" mode="IN"/>
    </service>

    <service name="launchExam" engine="java" location="com.sphinx.services.ExamTopicServices" invoke="launchExam" auth="false">
        <attribute name="examId" type="String" mode="IN"/>
    </service>
       
    
    <!-- Exam topic services end -->



    <!-- ====================================================================== -->
    <!-- ======================== EXAM SERVICES =========================== -->
    <!-- ====================================================================== -->
    
    <!-- Exam services -->
   <!--  <service name="createExam" engine="java" location="com.sphinx.services.ExamServices" invoke="createExam">
    <attribute name="examName" mode="IN" type="String" optional="false"/>
    <attribute name="description" mode="IN" type="String" optional="true"/>
    <attribute name="noOfQuestions" mode="IN" type="String" optional="false"/>
    <attribute name="duration" mode="IN" type="String" optional="false"/>
    <attribute name="passPercentage" mode="IN" type="String" optional="false"/>
    <attribute name="questionsRandomized" mode="IN" type="String" optional="true"/>
    <attribute name="answersMust" mode="IN" type="String" optional="true"/>
    <attribute name="allowNegativeMarks" mode="IN" type="String" optional="true"/>
    <attribute name="negativeMarkValue" mode="IN" type="String" optional="true"/>
    <attribute name="examId" mode="OUT" type="String" optional="true"/>
</service> -->

 <service name="createExamWrapper" engine="java" location="com.sphinx.services.ExamServices" invoke="createExam">
    <attribute name="examName" mode="IN" type="String" optional="false"/>
    <attribute name="description" mode="IN" type="String" optional="true"/>
    <attribute name="noOfQuestions" mode="IN" type="String" optional="false"/>
    <attribute name="duration" mode="IN" type="String" optional="false"/>
    <attribute name="passPercentage" mode="IN" type="String" optional="false"/>
    <attribute name="questionsRandomized" mode="IN" type="String" optional="true"/>
    <attribute name="answersMust" mode="IN" type="String" optional="true"/>
    <attribute name="allowNegativeMarks" mode="IN" type="String" optional="true"/>
    <attribute name="negativeMarkValue" mode="IN" type="String" optional="true"/>
    <attribute name="partyId" mode="IN" type="String" optional="true"></attribute>
    <attribute name="examId" mode="OUT" type="String" optional="true"/>
</service>


 <service name="createExam" engine="entity-auto" invoke="create" default-entity-name="ExamMaster">
        <auto-attributes include="pk" mode="INOUT" optional="true" />
        <auto-attributes include="nonpk" mode="IN" optional="true" />
    </service>
    
     <service name="AdminPartyRel" engine="entity-auto" invoke="create" default-entity-name="AdminPartyExamRel">
        <auto-attributes include="pk" mode="IN" optional="true" />
        <auto-attributes include="nonpk" mode="IN" optional="true" />
    </service>
    
    
    <service name="updateExam" engine="java" location="com.sphinx.services.ExamServices" invoke="updateExam" >
    <attribute name="examId" mode="IN" type="String" optional="false"/>
    <attribute name="examName" mode="IN" type="String" optional="false"/>
    <attribute name="description" mode="IN" type="String" optional="true"/>
    <attribute name="noOfQuestions" mode="IN" type="String" optional="false"/>
    <attribute name="duration" mode="IN" type="String" optional="false"/>
    <attribute name="passPercentage" mode="IN" type="String" optional="false"/>
    <attribute name="questionsRandomized" mode="IN" type="String" optional="true"/>
    <attribute name="answersMust" mode="IN" type="String" optional="true"/>
    <attribute name="allowNegativeMarks" mode="IN" type="String" optional="true"/>
    <attribute name="negativeMarkValue" mode="IN" type="String" optional="true"/>

  </service>

    <service name="deleteExam" engine="entity-auto" invoke="delete" default-entity-name="ExamMaster">
        <attribute name="examId" type="String" mode="IN"/>
    </service>

    <service name="getExam" engine="java" location="com.sphinx.services.ExamServices" invoke="getExam">
    <attribute name="examList" type="List" mode="OUT" optional="false" />
    
    </service>
    

    <service name="getExamById" engine="java"  location="com.sphinx.services.ExamTopicServices"  invoke="getExamById" >
    <attribute name="examId" type="String" mode="IN" optional="false"/>
    <attribute name="exam" type="Map" mode="OUT"/>

</service>

<service name="getExamTopicsByExamId"  engine="java"   location="com.sphinx.services.ExamTopicServices"   invoke="getExamTopicsByExamId" auth="false">
    <attribute name="examId" type="String" mode="IN" optional="false"/>
    <attribute name="examTopicList" type="List" mode="OUT" optional="true"/>

</service>

    <service  name="createPartyExamRelationshipInterface" engine="interface">
    	<attribute name="partyId" mode="IN" type="String" optional="false" />
    	<attribute name="examId" mode="IN" type="String" optional="false" />
    	<attribute name="allowedAttempts" mode="IN" type="Long" optional="false" />
    	<attribute name="noOfAttempts" mode="IN" type="Long" optional="false" />
    	<attribute name="timeoutDays" mode="IN" type="Long" optional="false" />
    </service>
   
   <service name="createPartyExamRelationshipWrapper" engine="java" location="com.sphinx.services.ExamServices" invoke="assignUsersToExam" auth="false">
    	<attribute name="users" mode="IN" type="List"></attribute>
    </service>
    
    <service name="createPartyExamRelationship" engine="entity-auto" default-entity-name="PartyExamRelationship" invoke="create" auth="false">
    	<implements service="createPartyExamRelationshipInterface"/>
    </service>
    
    <service name="getAllUsers" engine="java" location="com.sphinx.services.UserServices"  invoke="getAllUsers" auth="false">
    	<attribute name="users" mode="OUT" type="List"></attribute>
    </service>
     
    <service name="removeAssignedUserFromExamWrapper" engine="java" location="com.sphinx.services.ExamServices" invoke="removeAssignedUserFromExam" auth="false">
    	<attribute name="partyId" mode="IN" type="String" />
    	<attribute name="examId" mode="IN" type="String" />
    </service>
    
    <service name="removeAssignedUserFromExam" engine="entity-auto" invoke="delete" default-entity-name="PartyExamRelationship" auth="false">
    	<attribute name="partyId" mode="IN" type="String" />
    	<attribute name="examId" mode="IN" type="String" />
    </service>

<service name="getAllAssignedUsersForExam" engine="java" location="com.sphinx.services.ExamServices"  invoke="getAllAssignedUsersForExam" auth="false">
    	<attribute name="examId" mode="IN" type="String"></attribute>
    	<attribute name="data" mode="OUT" type="List"></attribute>
    </service>
    
    <service name="getAllExamAssignedForUser" engine="java" location="com.sphinx.services.ExamServices"  invoke="getAllExamAssignedForUser" auth="false">
    	<attribute name="partyId" mode="IN" type="String"></attribute>
    	<attribute name="data" mode="OUT" type="List"></attribute>
    </service>
    

    <!-- Exam service ended  -->
    
    
    <!-- ====================================================================== -->
    <!-- ======================== QUESTION SERVICES =========================== -->
    <!-- ====================================================================== -->

    <service name="questionFields" location="" invoke="" engine="interface">
        <attribute name="questionDetail" mode="IN" type="String" optional="false" />
        <attribute name="optionA" mode="IN" type="String" optional="false" />
        <attribute name="optionB" mode="IN" type="String" optional="false" />
        <attribute name="optionC" mode="IN" type="String" optional="true" />
        <attribute name="optionD" mode="IN" type="String" optional="true" />
        <attribute name="answer" mode="IN" type="String" optional="false" />
        <attribute name="numAnswers" mode="IN" type="String" optional="false" />
        <attribute name="questionType" mode="IN" type="String" optional="false" />
        <attribute name="difficultyLevel" mode="IN" type="String" optional="true" />
        <attribute name="answerValue" mode="IN" type="String" optional="true" />
        <attribute name="topicId" mode="IN" type="String" optional="false"/>
    </service>

    <service name="createQuestion" default-entity-name="QuestionMaster" engine="entity-auto" invoke="create">
        <implements service="questionFields" optional="false" />
        <attribute name="questionId" mode="INOUT" type="String" optional="true" />
    </service>
    
    <service name="updateQuestion" default-entity-name="QuestionMaster" engine="entity-auto" invoke="update">
        <implements service="questionFields" optional="false" />
        <attribute name="questionId" mode="IN" type="String" optional="true" />
    </service>
    
    <service name="deleteQuestion" default-entity-name="QuestionMaster" engine="entity-auto" invoke="delete">
        <attribute name="questionId" mode="IN" type="String" optional="false" />
    </service>

    <service name="getAllQuestionByTopic" engine="java" location="com.sphinx.services.QuestionService" invoke="getAllQuestionByTopic">
        <attribute name="topicId" type="String" mode="IN" />
    </service>
    
	<service name="getAllQuestionTypes" engine="java"
	    location="com.sphinx.services.QuestionService" invoke="getAllQuestionTypes">
	    <attribute name="data" type="List" mode="OUT" optional="true" />
	</service>
	
	<service name="downloadTemplateDocument" engine="java" location="com.sphinx.services.QuestionService" invoke="getTemplateDocument">
        <attribute name="bytes" mode="OUT" type="Byte []" optional="true" />
    </service>
    
    <service name="uploadBulkQuestion" engine="java" location="com.sphinx.services.QuestionService" invoke="uploadBulkQuestion">
        <attribute name="file" mode="IN" type="java.nio.ByteBuffer" optional="true" />
    </service>
    
    
    <service name="getUserAssignedExams" engine="java" location="in.vastpro.sphinx.ExamServices" invoke="getUserAssignedExams" auth="true">
    <attribute name="partyId"   type="String" mode="IN"  optional="false"/>
    <attribute name="examList"  type="List"   mode="OUT" optional="false"/>
</service>
	
</services>